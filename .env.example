# =============================================================================
# Upwork-VM-workflow -- environment template
# Copy to `.env` and fill in. Never commit the resulting .env file.
# =============================================================================

# --- Google Sheets sink ------------------------------------------------------

# Spreadsheet ID (from the sheet URL, between /d/ and /edit).
# Default points at the target sheet provided during planning.
GOOGLE_SHEET_ID=1wsLPktPzfIdf0dSKX0Ghxa21mnI8kdJ2FaZLAmX27QQ

# Tab name within the spreadsheet. Created on first run if absent.
GOOGLE_SHEET_TAB=upwork_master

# --- Job titles source ------------------------------------------------------

# Where to load the job titles + page counts from.
#   sheet -> read from GOOGLE_SHEET_JOB_TITLES_TAB in the same spreadsheet
#   csv   -> read from job_titles.csv (legacy / offline fallback)
JOB_TITLES_SOURCE=sheet
GOOGLE_SHEET_JOB_TITLES_TAB=Job Titles

# Path to the GCP service-account JSON key inside the container.
# Mount the key file via -v on the host, e.g.:
#   -v /opt/upwork-vm/sa.json:/secrets/sa.json:ro
GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json

# --- n8n webhook -------------------------------------------------------------

# Full webhook URL. Leave blank to disable notification (data still lands in
# the sheet; n8n will just not be poked).
N8N_WEBHOOK_URL=

# Optional shared secret sent as the X-Auth-Token header. Verify on n8n side.
N8N_WEBHOOK_TOKEN=

# Request timeout in seconds.
N8N_TIMEOUT=10

# --- Scraper -----------------------------------------------------------------

SCRAPING_MAX_WORKERS=3
SCRAPING_HEADLESS=true
SCRAPING_TIMEZONE_OFFSET=3
SCRAPING_TIMEOUT=300
SCRAPING_MAX_RETRIES=3
SCRAPING_JOBS_PER_PAGE=50
SCRAPING_START_PAGE=1
SCRAPING_SCRAPER_WORKERS=2
SCRAPING_FAST=false

# --- Upwork proxies ----------------------------------------------------------
# Comma-separated list of USER:PASS@HOST:PORT proxies (http:// prefix optional).
# Required on datacenter IPs (Contabo, Hetzner, etc.) -- Upwork's Cloudflare
# captchas every request from raw datacenter IPs. Leave blank to run without
# a proxy (works from residential IPs like your home network).
UPWORK_PROXIES=

# --- StableEncoder persistence ----------------------------------------------

# Where label_mappings.json lives. Volume-mount this directory so codes
# stay stable across container restarts.
LABEL_MAPPINGS_PATH=/app/state/label_mappings.json

# --- Logging -----------------------------------------------------------------

LOG_LEVEL=INFO
JSON_LOGS=false
